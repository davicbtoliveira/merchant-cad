# Variaveis de ambiente do Merchant CAD
#
# Nenhuma variavel de ambiente e obrigatoria para a execucao local padrao.
# Sem POSTGRES_DB, o Django usa SQLite em db.sqlite3.

# Opcional: sobrescreve o nome/caminho do banco de dados.
# Para SQLite, este e um caminho de arquivo relativo a raiz do projeto.
# Para PostgreSQL, isto sobrescreve POSTGRES_DB como NAME do banco no Django.
# DB_NAME=db.sqlite3

# Configuracao local de PostgreSQL sem Docker.
# Descomente e ajuste estes valores ao usar um servidor PostgreSQL local.
# POSTGRES_DB=merchant_cad
# POSTGRES_USER=merchant_cad
# POSTGRES_PASSWORD=merchant_cad
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
